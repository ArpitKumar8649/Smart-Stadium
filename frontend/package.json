{
  "name": "@concourse/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Concourse frontend — React PWA for the fan and admin views.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --emitDeclarationOnly false --noEmit && vite build",
    "preview": "vite preview --host --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=100"
  },
  "dependencies": {
    "@concourse/shared": "0.1.0",
    "@mapbox/polyline": "^1.2.1",
    "@react-leaflet/core": "^2.1.0",
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.14",
    "@types/cesium": "^1.67.14",
    "cesium": "^1.143.0",
    "d3-geo": "^3.1.1",
    "firebase": "^12.16.0",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "resium": "^1.24.0",
    "three": "^0.170.0",
    "vite-plugin-cesium": "^1.2.23"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@gltf-transform/cli": "^4.4.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-geo": "^3.1.0",
    "@types/leaflet": "^1.9.21",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-istanbul": "4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "msw": "^2.15.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.4",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
