{
  "name": "@concourse/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Concourse frontend — React PWA for the fan and admin views.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --emitDeclarationOnly false --noEmit && vite build",
    "preview": "vite preview --host --port 4173",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=100"
  },
  "dependencies": {
    "@concourse/shared": "0.1.0",
    "@mapbox/polyline": "^1.2.1",
    "@react-leaflet/core": "^2.1.0",
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.14",
    "d3-geo": "^3.1.1",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.2",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@types/d3-geo": "^3.1.0",
    "@types/leaflet": "^1.9.21",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vite-plugin-pwa": "^1.3.0"
  }
