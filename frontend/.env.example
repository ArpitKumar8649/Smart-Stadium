# --- Backend API base URL ---
VITE_API_BASE=http://localhost:8080

# --- Cesium Ion (3D map) ---
# Free at https://ion.cesium.com/ → Community plan includes Google Photorealistic
# 3D Tiles. Leave blank to fall back to Cesium's built-in demo token (throttled).
VITE_CESIUM_ION_TOKEN=

# --- Firebase Auth ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
