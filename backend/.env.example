# --- Runtime ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# --- DashScope (Qwen) — OpenAI-compatible endpoint ---
# Get a key at https://dashscope.console.aliyun.com/  (International endpoint below)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_CHAT=qwen-plus
QWEN_MODEL_VL=qwen-vl-max
QWEN_MODEL_EMBED=text-embedding-v3
# Max output tokens for one chat/concierge provider call (hard-capped at 2000).
QWEN_MAX_TOKENS=1200
# Reasoning ("thinking") mode: off | low | medium | high (Qwen3 models only).
QWEN_REASONING=off

# --- Google Routes API (outdoor GPS → stadium routing) ---
# Create a key in Google Cloud Console, enable "Routes API", and restrict it
# to the Routes API plus the Azure Web App's outbound IP addresses. This is a
# server-side key: do not use browser HTTP-referrer restrictions. Leave blank
# to disable outdoor routing — indoor navigation and everything else still works.
GOOGLE_ROUTES_API_KEY=

# --- Auth ---
FIREBASE_PROJECT_ID=

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173

# --- Crowd simulator ---
CROWD_SIM_ENABLED=true

# --- LLM concurrency guard (token bucket) ---
LLM_BUCKET_SIZE=12
LLM_BUCKET_REFILL_PER_MIN=12
# Maximum number of AI calls allowed to wait behind the token bucket.
LLM_MAX_QUEUE=24
