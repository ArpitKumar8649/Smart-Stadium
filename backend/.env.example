# --- Runtime ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# --- Google AI Studio (Gemini) ---
# Get at https://aistudio.google.com/apikey (no credit card required)
GEMINI_API_KEY=

# --- Gemini model selection ---
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_EMBED=text-embedding-004

# --- Firebase Admin (server-side) ---
# Paste the JSON as a single-line string, or point to a path
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternative:
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json
FIREBASE_PROJECT_ID=

# --- Auth ---
# Space-separated Firebase UIDs allowed to hit /api/admin/*
ADMIN_UIDS=

# --- CORS ---
# Comma-separated list of origins allowed in production
ALLOWED_ORIGINS=http://localhost:5173

# --- Crowd simulator ---
CROWD_SIM_ENABLED=true

# --- Rate limiting ---
GEMINI_BUCKET_SIZE=12
GEMINI_BUCKET_REFILL_PER_MIN=12
