# --- Runtime ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# --- DashScope (Qwen) — OpenAI-compatible endpoint ---
# Get a key at https://dashscope.console.aliyun.com/  (International endpoint below)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_CHAT=qwen-plus
QWEN_MODEL_VL=qwen-vl-max
QWEN_MODEL_EMBED=text-embedding-v3
# Max output tokens for chat/concierge completions.
QWEN_MAX_TOKENS=64000
# Reasoning ("thinking") mode: off | low | medium | high (Qwen3 models only).
QWEN_REASONING=off

# --- Firebase Admin (server-side) ---
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=

# --- Google Routes API (outdoor GPS → stadium routing) ---
# Create a key in Google Cloud Console, enable "Routes API", and restrict it
# (Routes API only + HTTP-referrer/IP allowlist). Leave blank to disable outdoor
# routing — indoor navigation and everything else still works.
GOOGLE_ROUTES_API_KEY=

# --- Auth ---
# Space-separated Firebase UIDs allowed to hit /api/admin/* (future Firebase mode)
ADMIN_UIDS=
# Local/demo admin token (minimum 12 characters). Never put this in frontend env vars.
ADMIN_DEMO_TOKEN=

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173

# --- Crowd simulator ---
CROWD_SIM_ENABLED=true

# --- LLM concurrency guard (token bucket) ---
LLM_BUCKET_SIZE=12
LLM_BUCKET_REFILL_PER_MIN=12
