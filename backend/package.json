{
  "name": "@concourse/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Concourse backend — Express + Gemini agent + crowd simulator + SSE.",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=100",
    "test": "vitest run"
  },
  "dependencies": {
    "@concourse/shared": "0.1.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "firebase-admin": "^12.1.0",
    "helmet": "^7.2.0",
    "openai": "^4.104.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "vite": "8.1.5",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.1",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
}
